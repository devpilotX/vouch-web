# Copy this file to .env.local and fill in real values.
# Never commit the real .env.local. It is already in .gitignore.

# Resend is what actually stores waitlist signups.
# Grab these from https://resend.com once the account is set up.
# Leave them blank in dev and the form still works (it just logs the email).
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Plausible analytics. Set this to the site domain (for example vouch.family).
# Leave it blank and no analytics script loads at all.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
